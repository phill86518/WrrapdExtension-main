{
  "rule": [
    {
      "action": { "type": "SetStorageClass", "storageClass": "NEARLINE" },
      "condition": { "age": 60, "matchesPrefix": ["proof/"] }
    },
    {
      "action": { "type": "Delete" },
      "condition": { "age": 365, "matchesPrefix": ["proof/"] }
    },
    {
      "action": { "type": "Delete" },
      "condition": { "age": 30, "isLive": false, "matchesPrefix": ["proof/"] }
    }
  ]
}
