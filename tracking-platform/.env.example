# Optional: public URL of this service (https://….run.app). Fixes redirects when Cloud Run reports Host=localhost:8080.
TRACKING_PUBLIC_ORIGIN=

# Solo founder: always treat this driver as available (both shifts, every week, no deadline).
TRACKING_FOUNDER_DRIVER_ID=drv-1
# When set, every auto-assigned order goes to this driver (e.g. drv-1 / Roger). Remove when you hire a second driver.
TRACKING_SOLO_DRIVER_ID=drv-1

# Thank-you + delivery-choice + admin ops emails (Mailgun — same as pay server). Admin manual creates skip notify.
# MAILGUN_API_KEY=key-...
# MAILGUN_DOMAIN=mg.wrrapd.com
# Optional EU region: MAILGUN_REGION=eu
# NOTIFY_EMAIL_FROM="Wrrapd Orders <orders@wrrapd.com>"
# NOTIFY_EMAIL_REPLY_TO=support@wrrapd.com
# Comma-separated — each gets a detailed "New order" message.
# NOTIFY_ADMIN_ORDER_EMAILS=admin@wrrapd.com,angel@wrrapd.com
# TWILIO_ACCOUNT_SID=...
# TWILIO_AUTH_TOKEN=...
# TWILIO_SMS_FROM=+1...
# TRACKING_NOTIFY_NEW_ORDERS=false
# CRON_SECRET=...  (for POST /api/jobs/expire-delivery-preferences with x-cron-secret)

APP_SESSION_SECRET=change-me-in-production
APP_ADMIN_PASSWORD=admin123
APP_DRIVER_PASSWORD=driver123
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Recommended on Cloud Run: PEM file contents as UTF-8, then base64 (single line, no newline issues).
# If set, this wins over FIREBASE_PRIVATE_KEY.
FIREBASE_PRIVATE_KEY_BASE64=
# Omit or set to (default) for the default database. Named DB in Firebase: e.g. wrrapd-firebase-db01
FIREBASE_FIRESTORE_DATABASE_ID=(default)
GCS_BACKUP_BUCKET=
# Same bucket is fine if it is (or is also) a Firebase Storage bucket
FIREBASE_STORAGE_BUCKET=
# Server-to-server order ingest (extension / checkout). If unset, POST /api/orders/ingest returns 503.
INGEST_API_KEY=
# Cloud Run: startup fails unless Firebase is configured (disk is ephemeral). Local dev: optional.
# TRACKING_REQUIRE_FIRESTORE=true — same check locally. TRACKING_ALLOW_EPHEMERAL=true — bypass (not production).
