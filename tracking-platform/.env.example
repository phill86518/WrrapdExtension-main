APP_SESSION_SECRET=change-me-in-production
APP_ADMIN_PASSWORD=admin123
APP_DRIVER_PASSWORD=driver123
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Recommended on Cloud Run: PEM file contents as UTF-8, then base64 (single line, no newline issues).
# If set, this wins over FIREBASE_PRIVATE_KEY.
FIREBASE_PRIVATE_KEY_BASE64=
# Omit or set to (default) for the default database. Named DB in Firebase: e.g. wrrapd-firebase-db01
FIREBASE_FIRESTORE_DATABASE_ID=(default)
GCS_BACKUP_BUCKET=
# Same bucket is fine if it is (or is also) a Firebase Storage bucket
FIREBASE_STORAGE_BUCKET=
# Server-to-server order ingest (extension / checkout). If unset, POST /api/orders/ingest returns 503.
INGEST_API_KEY=
# Cloud Run: startup fails unless Firebase is configured (disk is ephemeral). Local dev: optional.
# TRACKING_REQUIRE_FIRESTORE=true — same check locally. TRACKING_ALLOW_EPHEMERAL=true — bypass (not production).
